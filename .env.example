# URL of your Spoolman instance
SPOOLMAN_URL=http://spoolman:7912

# AI provider — set ONE of the two keys below.
# OpenRouter is used when OPENROUTER_API_KEY is set; otherwise Anthropic is used.

# OpenRouter API key — get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Model to use via OpenRouter (default: anthropic/claude-haiku-4-5)
OPENROUTER_MODEL=anthropic/claude-haiku-4-5

# Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Spoolman API key (leave blank if not configured)
SPOOLMAN_API_KEY=
